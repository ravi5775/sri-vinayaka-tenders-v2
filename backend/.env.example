# Runtime
NODE_ENV=development
PORT=5000
AUTO_MIGRATE_ON_BOOT=false
API_BODY_LIMIT=5mb

# Frontend and CORS (comma-separated list allowed)
FRONTEND_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# PostgreSQL (preferred on Vercel)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sri_vinayaka
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/sri_vinayaka
PG_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=3000
DB_STATEMENT_TIMEOUT_MS=30000

# Legacy PostgreSQL fallback (used only when DATABASE_URL is unset)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sri_vinayaka
DB_USER=postgres
DB_PASSWORD=postgres

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=24h

# Email
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_AUTH_REQUIRED=true
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=Sri Vinayaka Tenders
EMAIL_REPLY_TO=
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY_SECONDS=5

# Optional Mongo backup
MONGODB_URI=
MONGO_URI=
MONGO_DB_NAME=sri_vinayaka_backups
MONGO_HOST=
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_APP_NAME=SriVinayakaTenders

# ═════════════════════════════════════════════════════════════
# AUTOMATED BACKUP CONFIGURATION
# ═════════════════════════════════════════════════════════════

# Enable/disable automatic backup jobs
ENABLE_SCHEDULED_BACKUPS=true

# MongoDB Atlas Backup (every 3 hours automatically)
# Already uses MONGODB_URI from above

# Google Drive Backup Configuration
# For automatic Google Drive backups, configure:
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Backup schedules (do not change - configured in code)
# MongoDB Atlas: Every 3 hours (automatic)
# Google Drive: Every 6 hours (automatic)
# Transaction Trigger: Every 3 transactions (automatic)
# Local Device: Manual anytime + Transaction triggered

# Backup paths (local storage)
BACKUP_DIR=./backups
